# ── LeadGen AI Agent — Environment Variables ──────────────────────────────

# REQUIRED
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPTIONAL — Email (SMTP) — uncomment when ready to send real emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SENDER_EMAIL=you@gmail.com
# SENDER_PASSWORD=your_app_password
# SENDER_NAME=Your Name

# OPTIONAL — WhatsApp Business API (Twilio or Meta)
# WHATSAPP_API_URL=https://api.twilio.com/...
# WHATSAPP_TOKEN=your_token
# WHATSAPP_FROM=whatsapp:+14155238886
# DATABASE_URL=postgresql://user:password@host:5432/leadgen
